import 'package:mindcoach/core/utils/locale_font_scaler.dart';
import 'package:mindcoach/core/utils/context_l10n_extensions.dart';
import 'package:mindcoach/core/utils/screen_size_extensions.dart';

import 'package:mindcoach/features/chat_screen/constants/conversation_strings.dart';
import 'package:mindcoach/features/chat_screen/constants/chat_strings.dart';
