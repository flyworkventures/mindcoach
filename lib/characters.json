server {
    server_name barcode.fly-work.com;

    location / {
        proxy_pass http://localhost:3029;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    listen 443 ssl;
    #ssl_certificate /etc/letsencrypt/live/barcode.fly-work.com/fullchain.pem; 
    #ssl_certificate_key /etc/letsencrypt/live/barcode.fly-work.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = barcode.fly-work.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name barcode.fly-work.com;
    return 404; # managed by Certbot


}


npm install @google-cloud/vision